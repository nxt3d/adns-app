# Reown / WalletConnect project id (https://cloud.reown.com). Required for the wallet modal.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Public site URL (used in wallet metadata). Production: https://adns.cc
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mainnet RPC URL. Must be NEXT_PUBLIC_ to reach the browser wallet/wagmi client.
# Leave blank to fall back to viem's default public mainnet RPC (fine for local dev).
NEXT_PUBLIC_MAINNET_RPC_URL=

# aDNS indexer (server-side only — proxied through /api/adns/*, never exposed to
# the browser). Leave ADNS_INDEXER_URL blank to disable the indexer and fall
# back to direct contract reads.
ADNS_INDEXER_URL=https://adns-indexer.onrender.com
ADNS_INDEXER_PROXY_SECRET=
