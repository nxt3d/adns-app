# WalletConnect / RainbowKit project id (https://cloud.reown.com / cloud.walletconnect.com).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Public site URL (wallet metadata). Production: https://adns.cc
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mainnet RPC URL — SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix). Carries the
# Alchemy API key; it is proxied through /api/rpc and never reaches the browser.
# Leave blank to fall back to viem's default public mainnet RPC (fine for local dev).
MAINNET_RPC_URL=

# Admin contact for v1 parent-allocation requests (homepage "Reserve" button).
NEXT_PUBLIC_ALLOCATION_CONTACT=mailto:hello@adns.cc

# ADNS indexer (server-side only — proxied through /api/adns/*, never exposed to
# the browser). Leave ADNS_INDEXER_URL blank to disable the indexer.
ADNS_INDEXER_URL=https://adns-indexer.onrender.com
ADNS_INDEXER_PROXY_SECRET=
